# Fuglehundprøve - Miljøvariabler
# Kopier til .env og fyll inn verdier

# Server
PORT=8889
NODE_ENV=development

# JWT Auth - generer ny secret med: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./fuglehund.db

# Site-wide passordbeskyttelse (valgfritt)
# Sett en PIN her for å kreve innlogging før siden vises
# La stå tom for å deaktivere
SITE_PIN=

# Admin-beskyttelse (anbefalt for produksjon)
# Egen PIN for admin-sider (admin.html, admin-panel.html)
ADMIN_PIN=

# SMS via Sveve (sveve.no) - legacy
SVEVE_USER=
SVEVE_PASS=

# SMS via Twilio (anbefalt)
# Opprett konto på twilio.com og hent credentials fra Console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Messaging Service for Alpha Sender (valgfritt, men anbefalt for visningsnavn)
TWILIO_MESSAGING_SERVICE_SID=
