# Fuglehundprøve - Miljøvariabler
# Kopier til .env og fyll inn verdier

# Server
PORT=8889
NODE_ENV=development

# JWT Auth - KRITISK FOR SIKKERHET
# I produksjon MÅ du sette en sterk, unik hemmelighet!
# Generer med: openssl rand -hex 32
# ELLER: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Serveren vil IKKE starte i produksjon uten JWT_SECRET!
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./fuglehund.db

# Site-wide passordbeskyttelse (valgfritt)
# Sett en PIN her for å kreve innlogging før siden vises
# La stå tom for å deaktivere
SITE_PIN=

# Admin-beskyttelse (anbefalt for produksjon)
# Egen PIN for admin-sider (admin.html, admin-panel.html)
ADMIN_PIN=

# SMS via Sveve (sveve.no) - PRIMÆR
# Opprett konto på sveve.no og hent API-nøkkel fra API-seksjonen
SVEVE_USER=
SVEVE_PASS=
SVEVE_FROM=Fuglehund

# SMS via Twilio (backup/legacy)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ============================================
# VIPPS BUSINESS API OPPSETT
# ============================================
# Hver klubb kan konfigurere sin egen Vipps Business-integrasjon
# via klubb-administrasjonen i systemet.
#
# VIKTIG: Webhook-registrering
# For at automatisk statusoppdatering skal fungere, må klubben
# registrere webhook-URL i Vipps Merchant Portal:
#
# 1. Logg inn på https://portal.vipps.no
# 2. Gå til "Utvikler" > "Webhooks"
# 3. Legg til ny webhook med:
#    - URL: https://fuglehundprove.no/api/vipps/webhook
#    - Events: EPAYMENTS (alle events)
#
# Uten webhook må admin manuelt sjekke betalingsstatus.
# Webhook-endepunktet støtter følgende Vipps-tilstander:
#   - AUTHORIZED/CAPTURED/SALE -> Markerer som betalt
#   - TERMINATED/EXPIRED -> Markerer som kansellert
