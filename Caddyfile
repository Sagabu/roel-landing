# Fuglehundprove production Caddy config
# Replace YOUR_DOMAIN with actual domain (e.g., fuglehundprove.no)

YOUR_DOMAIN {
    reverse_proxy localhost:8889

    # Compression
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Logs
    log {
        output file /var/log/caddy/fuglehund.log
        format json
    }
}
